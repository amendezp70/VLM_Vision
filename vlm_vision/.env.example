# vlm_vision/.env.example
#
# Copy to .env and edit:  cp .env.example .env
#
# Platform notes:
#   macOS  — run with:  ./scripts/run_mac.sh
#   Windows — run with:  scripts\run_windows.bat
#   Docker  — run with:  docker compose up --build

MODEL_PATH=models/metwall.onnx
MODEL_DIR=models
CAMERA_BAY1=0
CAMERA_BAY2=1
MODULA_WMS_URL=http://modula-wms.local:8080
CLOUD_SYNC_URL=https://catalyst.zoho.com/baas/v1/project/YOUR_PROJECT_ID
DETECTION_FPS=10
WEBSOCKET_PORT=8765
DB_PATH=data/picks.db
SYNC_INTERVAL_SEC=30
MODEL_POLL_INTERVAL_SEC=3600
